<page-meta class="data-v-83a5a03c" root-font-size="system" />
<view class="page data-v-83a5a03c">
    <view class="banner data-v-83a5a03c">
        <view class="banner-left data-v-83a5a03c">
            <image class="avatar data-v-83a5a03c" src="{{a}}" mode="aspectFill" />
            <view class="user-info data-v-83a5a03c"><text class="welcome data-v-83a5a03c">{{b}}</text><text class="unit data-v-83a5a03c">{{c}}</text></view>
        </view>
        <view class="banner-logo-text data-v-83a5a03c">志愿</view>
    </view>
    <view wx:if="{{d}}" class="stat-card data-v-83a5a03c">
        <view class="stat-item data-v-83a5a03c"><text class="stat-num data-v-83a5a03c">{{e}}</text><text class="stat-label data-v-83a5a03c">服务时长(h)</text></view>
        <view class="stat-divider data-v-83a5a03c"></view>
        <view class="stat-item data-v-83a5a03c"><text class="stat-num data-v-83a5a03c">{{f}}</text><text class="stat-label data-v-83a5a03c">参与活动</text></view>
        <view class="stat-divider data-v-83a5a03c"></view>
        <view class="stat-item data-v-83a5a03c"><text class="stat-num data-v-83a5a03c">{{g}}</text><text class="stat-label data-v-83a5a03c">服务人次</text></view>
    </view>
    <view class="section data-v-83a5a03c"><text class="section-title data-v-83a5a03c">功能模块</text>
        <view class="module-card module-primary data-v-83a5a03c" bindtap="{{j}}">
            <view class="module-icon-wrap data-v-83a5a03c">
                <icon wx:if="{{h}}" class="module-icon data-v-83a5a03c" u-i="83a5a03c-0" bind:__l="__l" u-p="{{h}}" />
            </view>
            <view class="module-info data-v-83a5a03c"><text class="module-name data-v-83a5a03c">志愿活动</text><text class="module-desc data-v-83a5a03c">报名参加、打卡记录、统计报表</text></view>
            <icon wx:if="{{i}}" class="module-arrow data-v-83a5a03c" u-i="83a5a03c-1" bind:__l="__l" u-p="{{i}}" />
        </view>
    </view>
    <view class="section data-v-83a5a03c"><text class="section-title data-v-83a5a03c">快捷入口</text>
        <view class="quick-grid data-v-83a5a03c">
            <view class="quick-item data-v-83a5a03c" bindtap="{{l}}">
                <view class="quick-icon-wrap quick-icon-1 data-v-83a5a03c">
                    <icon wx:if="{{k}}" class="quick-icon data-v-83a5a03c" u-i="83a5a03c-2" bind:__l="__l" u-p="{{k}}" />
                </view>
                <view class="quick-text data-v-83a5a03c"><text class="quick-label data-v-83a5a03c">活动报名</text><text class="quick-desc data-v-83a5a03c">浏览并报名志愿活动</text></view>
            </view>
            <view class="quick-item data-v-83a5a03c" bindtap="{{n}}">
                <view class="quick-icon-wrap quick-icon-2 data-v-83a5a03c">
                    <icon wx:if="{{m}}" class="quick-icon data-v-83a5a03c" u-i="83a5a03c-3" bind:__l="__l" u-p="{{m}}" />
                </view>
                <view class="quick-text data-v-83a5a03c"><text class="quick-label data-v-83a5a03c">志愿打卡</text><text class="quick-desc data-v-83a5a03c">已报名活动打卡记录</text></view>
            </view>
            <view class="quick-item data-v-83a5a03c" bindtap="{{p}}">
                <view class="quick-icon-wrap quick-icon-3 data-v-83a5a03c">
                    <icon wx:if="{{o}}" class="quick-icon data-v-83a5a03c" u-i="83a5a03c-4" bind:__l="__l" u-p="{{o}}" />
                </view>
                <view class="quick-text data-v-83a5a03c"><text class="quick-label data-v-83a5a03c">打卡记录</text><text class="quick-desc data-v-83a5a03c">查看历史打卡记录</text></view>
            </view>
            <view class="quick-item data-v-83a5a03c" bindtap="{{r}}">
                <view class="quick-icon-wrap quick-icon-4 data-v-83a5a03c">
                    <icon wx:if="{{q}}" class="quick-icon data-v-83a5a03c" u-i="83a5a03c-5" bind:__l="__l" u-p="{{q}}" />
                </view>
                <view class="quick-text data-v-83a5a03c"><text class="quick-label data-v-83a5a03c">统计报表</text><text class="quick-desc data-v-83a5a03c">查看个人服务统计</text></view>
            </view>
        </view>
    </view>
</view>