.page.data-v-9a7a0f56 {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7f9fc 0%, #eef2f7 48%, #e9eef5 100%);
  display: flex;
  flex-direction: column;
}
.tabs-wrap.data-v-9a7a0f56 {
  background: #fff;
  border-bottom: 1rpx solid #eee;
}
.stat-bar.data-v-9a7a0f56 {
  background: linear-gradient(135deg, #eef6ff 0%, #e0efff 100%);
  padding: 14px 16px;
  box-shadow: 0 2px 12px rgba(47, 98, 198, 0.08);
}
.stat-bar-text.data-v-9a7a0f56 {
  font-size: 14px;
  color: #2f62c6;
  font-weight: 700;
}
.scroll-wrap.data-v-9a7a0f56 {
  flex: 1;
  height: 0;
  min-height: calc(100vh - 88px);
}
.loading-wrap.data-v-9a7a0f56 {
  display: flex;
  justify-content: center;
  padding: 80px 0;
}
.list-wrap.data-v-9a7a0f56 {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.record-card.data-v-9a7a0f56 {
  background: #fff;
  border-radius: 18px;
  padding: 18px;
  box-shadow: 0 10px 20px rgba(20, 28, 46, 0.08);
  animation: riseIn-9a7a0f56 0.45s ease-out both;
}
.card-head.data-v-9a7a0f56 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}
.user-wrap.data-v-9a7a0f56 {
  display: flex;
  align-items: center;
}
.user-name.data-v-9a7a0f56 {
  font-size: 16px;
  font-weight: 700;
  color: #333;
  margin-right: 8px;
}
.user-phone.data-v-9a7a0f56 {
  font-size: 14px;
  color: #7a8797;
}
.status-badge.data-v-9a7a0f56 {
  font-size: 12px;
  font-weight: 700;
  padding: 4px 12px;
  border-radius: 20px;
}
.activity-name.data-v-9a7a0f56 {
  font-size: 18px;
  font-weight: 700;
  color: #1c2431;
  margin-bottom: 10px;
}
.card-row.data-v-9a7a0f56 {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 10px;
}
.row-icon.data-v-9a7a0f56 {
  font-size: 16px;
  width: 20px;
  text-align: center;
}
.row-text.data-v-9a7a0f56 {
  font-size: 14px;
  color: #7a8797;
}
.metrics-row.data-v-9a7a0f56 {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #f7f9fc 0%, #eef3fc 100%);
  border-radius: 14px;
  padding: 16px 0;
  margin: 14px 0;
}
.metric-item.data-v-9a7a0f56 {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}
.metric-num.data-v-9a7a0f56 {
  font-size: 24px;
  font-weight: 700;
  color: #2f62c6;
}
.metric-label.data-v-9a7a0f56 {
  font-size: 12px;
  color: #7a8797;
}
.metric-divider.data-v-9a7a0f56 {
  width: 1px;
  height: 32px;
  background: #e6ebf2;
}
.remark-row.data-v-9a7a0f56 {
  display: flex;
  margin-top: 12px;
  background: linear-gradient(135deg, #fffcf5 0%, #fff9eb 100%);
  padding: 12px;
  border-radius: 10px;
}
.reason-row.data-v-9a7a0f56 {
  background: #fdf2f1;
}
.remark-label.data-v-9a7a0f56 {
  font-size: 13px;
  color: #a0aab5;
  flex-shrink: 0;
  font-weight: 600;
}
.remark-text.data-v-9a7a0f56 {
  font-size: 14px;
  color: #6b7b8d;
  line-height: 1.6;
}
.photos-wrap.data-v-9a7a0f56 {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 14px;
}
.photo-item.data-v-9a7a0f56 {
  width: calc((100% - 20px) / 3);
  height: 90px;
  border-radius: 10px;
  background: #f7f9fc;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}
.action-footer.data-v-9a7a0f56 {
  display: flex;
  justify-content: flex-end;
  gap: 12px;
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1rpx dashed #eee;
}
.action-btn.data-v-9a7a0f56 {
  padding: 8px 24px;
  border-radius: 20px;
  font-size: 14px;
  font-weight: 600;
  text-align: center;
}
.btn-reject.data-v-9a7a0f56 {
  color: #e74c3c;
  background: #fde8e8;
}
.btn-approve.data-v-9a7a0f56 {
  color: #fff;
  background: #3a7bd5;
  box-shadow: 0 4px 10px rgba(58, 123, 213, 0.3);
}
.empty.data-v-9a7a0f56 {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100px 16px;
  gap: 14px;
}
.empty-icon.data-v-9a7a0f56 {
  font-size: 72px;
  opacity: 0.5;
}
.empty-text.data-v-9a7a0f56 {
  font-size: 16px;
  font-weight: 700;
  color: #7a8797;
}
.no-more.data-v-9a7a0f56 {
  text-align: center;
  padding: 24px 0;
  font-size: 13px;
  color: #a0aab5;
}
.btn-detail.data-v-9a7a0f56 {
  color: #3a7bd5;
  background: #eef6ff;
}

/* 原生弹窗与自定义 Tabs 样式 */
.custom-tabs.data-v-9a7a0f56 {
  display: flex;
  height: 44px;
  background: #fff;
  align-items: center;
  justify-content: space-around;
}
.custom-tab.data-v-9a7a0f56 {
  position: relative;
  font-size: 14px;
  color: #666;
  padding: 10px 16px;
  font-weight: 500;
  transition: all 0.3s;
}
.custom-tab-active.data-v-9a7a0f56 {
  color: #3a7bd5;
  font-weight: 700;
}
.custom-tab-line.data-v-9a7a0f56 {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 20px;
  height: 3px;
  background-color: #3a7bd5;
  border-radius: 2px;
}
.native-popup-mask.data-v-9a7a0f56 {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  animation: fadeIn-9a7a0f56 0.3s ease;
}
@keyframes fadeIn-9a7a0f56 {
from {
    opacity: 0;
}
to {
    opacity: 1;
}
}
.native-popup-content.data-v-9a7a0f56 {
  background: #fff;
  border-radius: 20px 20px 0 0;
  padding: 20px 0;
  display: flex;
  flex-direction: column;
  max-height: 80vh;
  animation: slideUp-9a7a0f56 0.3s ease;
}
@keyframes slideUp-9a7a0f56 {
from {
    transform: translateY(100%);
}
to {
    transform: translateY(0);
}
}
.popup-header.data-v-9a7a0f56 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 20px 16px;
  border-bottom: 1rpx solid #eee;
}
.popup-title.data-v-9a7a0f56 {
  font-size: 18px;
  font-weight: bold;
  color: #333;
}
.popup-scroll.data-v-9a7a0f56 {
  flex: 1;
  padding: 20px;
  max-height: calc(80vh - 60px);
}
.detail-item.data-v-9a7a0f56 {
  display: flex;
  margin-bottom: 16px;
  line-height: 1.5;
}
.detail-label.data-v-9a7a0f56 {
  width: 80px;
  flex-shrink: 0;
  font-size: 14px;
  color: #7a8797;
}
.detail-value.data-v-9a7a0f56 {
  flex: 1;
  font-size: 14px;
  color: #333;
  word-break: break-all;
}
@keyframes riseIn-9a7a0f56 {
from {
    opacity: 0;
    transform: translateY(8px);
}
to {
    opacity: 1;
    transform: translateY(0);
}
}