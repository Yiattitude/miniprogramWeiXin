.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7f9fc 0%, #eef2f7 48%, #e9eef5 100%);
  padding: 16px 16px 44px;
  font-family: "HarmonyOS Sans", "PingFang SC", "Microsoft YaHei", sans-serif;
}

.header-card {
  background: linear-gradient(135deg, #2f62c6 0%, #3e7ae4 100%);
  border-radius: 18px;
  padding: 20px;
  color: #fff;
  box-shadow: 0 12px 24px rgba(29, 55, 107, 0.2);
  animation: riseIn 0.45s ease-out both;
}

.header-title {
  font-size: 20px;
  font-weight: 700;
}

.header-desc {
  font-size: 13px;
  margin-top: 6px;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
}

.form-card {
  background: #fff;
  border-radius: 18px;
  padding: 20px;
  box-shadow: 0 12px 24px rgba(29, 55, 107, 0.1);
  margin-top: 16px;
  animation: riseIn 0.45s ease-out both;
  animation-delay: 0.05s;
}

.form-item {
  padding: 18px 0;
  border-bottom: 1px solid #f0f2f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  display: block;
  font-size: 15px;
  color: #1c2431;
  font-weight: 700;
  margin-bottom: 12px;
}

.required {
  color: #e74c3c;
}

.form-input {
  width: 100%;
  height: 48px;
  background: #f7f9fc;
  border-radius: 12px;
  padding: 0 14px;
  font-size: 15px;
  color: #1c2431;
  box-sizing: border-box;
  border: 2px solid transparent;
  transition: all 0.2s ease;
}

.form-input:focus {
  background: #fff;
  border-color: #2f62c6;
  box-shadow: 0 0 0 3px rgba(47, 98, 198, 0.1);
}

.form-textarea {
  width: 100%;
  min-height: 120px;
  background: #f7f9fc;
  border-radius: 12px;
  padding: 14px;
  font-size: 15px;
  color: #1c2431;
  box-sizing: border-box;
  line-height: 1.6;
  border: 2px solid transparent;
  transition: all 0.2s ease;
}

.form-textarea:focus {
  background: #fff;
  border-color: #2f62c6;
  box-shadow: 0 0 0 3px rgba(47, 98, 198, 0.1);
}

.picker-display {
  height: 48px;
  line-height: 48px;
  background: #f7f9fc;
  border-radius: 12px;
  padding: 0 14px;
  font-size: 15px;
  color: #1c2431;
  transition: all 0.2s ease;
}

.notice-card {
  margin-top: 16px;
  background: #fff7e8;
  border: 1px solid #ffe1a6;
  border-radius: 14px;
  padding: 12px 14px;
  animation: riseIn 0.45s ease-out both;
  animation-delay: 0.1s;
}

.notice-text {
  font-size: 13px;
  color: #8a5a00;
  line-height: 1.6;
}

.btn-group {
  margin-top: 24px;
  animation: riseIn 0.45s ease-out both;
  animation-delay: 0.15s;
}

.btn-submit {
  width: 100%;
  height: 52px;
  background: linear-gradient(135deg, #2f62c6 0%, #3e7ae4 100%);
  color: #fff;
  font-size: 17px;
  font-weight: 700;
  border-radius: 26px;
  border: none;
  letter-spacing: 2px;
  box-shadow: 0 8px 20px rgba(47, 98, 198, 0.3);
  transition: all 0.3s ease;
}

.btn-submit:active {
  transform: scale(0.98);
}

@keyframes riseIn {
  from {
    opacity: 0;
    transform: translateY(8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
