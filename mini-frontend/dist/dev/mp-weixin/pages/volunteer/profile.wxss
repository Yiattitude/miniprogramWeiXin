.page.data-v-dd49826d {
  min-height: 100vh;
  background: var(--color-bg-page, #f0f2f5);
  padding-bottom: 40px;
}

/* 头部 */
.profile-header.data-v-dd49826d {
  background: linear-gradient(135deg, #3a7bd5 0%, #2a5caa 100%);
  padding: 40px var(--space-md, 16px) 60px;
  display: flex;
  align-items: center;
  gap: var(--space-md, 16px);
}
.avatar.data-v-dd49826d {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  border: 3px solid rgba(255, 255, 255, 0.7);
  background: rgba(255, 255, 255, 0.2);
  flex-shrink: 0;
}
.user-meta.data-v-dd49826d {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.nickname.data-v-dd49826d {
  font-size: var(--font-xl, 22px);
  font-weight: 700;
  color: #fff;
}
.unit-row.data-v-dd49826d {
  display: flex;
  align-items: center;
  gap: 4px;
}
.unit-icon.data-v-dd49826d {
  font-size: 15px;
}
.unit-text.data-v-dd49826d {
  font-size: var(--font-sm, 15px);
  color: rgba(255, 255, 255, 0.85);
}
.role-badge.data-v-dd49826d {
  display: inline-block;
  padding: 3px 10px;
  border-radius: 20px;
  font-size: var(--font-xs, 13px);
  font-weight: 600;
  width: -moz-fit-content;
  width: fit-content;
}
.role-badge.role-admin.data-v-dd49826d {
  background: #ffc107;
  color: #856404;
}
.role-badge.role-member.data-v-dd49826d {
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
}

/* 统计卡片 */
.stat-card.data-v-dd49826d {
  background: #fff;
  margin: -36px var(--space-md, 16px) var(--space-md, 16px);
  border-radius: var(--radius-lg, 16px);
  padding: var(--space-md, 16px);
  display: flex;
  align-items: center;
  box-shadow: 0 4px 20px rgba(58, 123, 213, 0.15);
  position: relative;
  z-index: 1;
}
.stat-item.data-v-dd49826d {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}
.stat-num.data-v-dd49826d {
  font-size: var(--font-xl, 22px);
  font-weight: 700;
  color: var(--color-primary, #3a7bd5);
}
.stat-label.data-v-dd49826d {
  font-size: var(--font-xs, 13px);
  color: var(--color-text-sub, #6b7b8d);
}
.stat-divider.data-v-dd49826d {
  width: 1px;
  height: 40px;
  background: var(--color-border, #e2e7ec);
  flex-shrink: 0;
}

/* 功能菜单 */
.menu-section.data-v-dd49826d {
  margin: 0 var(--space-md, 16px) var(--space-md, 16px);
}
.section-title.data-v-dd49826d {
  font-size: var(--font-base, 17px);
  font-weight: 600;
  color: var(--color-text-main, #1e2a3a);
  padding: var(--space-sm, 12px) 0 var(--space-xs, 8px);
}
.menu-card.data-v-dd49826d {
  background: #fff;
  border-radius: var(--radius-md, 10px);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  overflow: hidden;
}
.menu-item.data-v-dd49826d {
  display: flex;
  align-items: center;
  gap: var(--space-sm, 12px);
  padding: var(--space-md, 16px);
  min-height: var(--tap-min-size, 44px);
}
.menu-icon-wrap.data-v-dd49826d {
  width: 44px;
  height: 44px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.menu-icon.data-v-dd49826d {
  font-size: 24px;
}
.menu-label.data-v-dd49826d {
  flex: 1;
  font-size: var(--font-base, 17px);
  color: var(--color-text-main, #1e2a3a);
  font-weight: 500;
}
.admin-tag.data-v-dd49826d {
  background: #fff3cd;
  color: #856404;
  font-size: var(--font-xs, 13px);
  font-weight: 600;
  padding: 2px 8px;
  border-radius: 10px;
  margin-right: 4px;
}
.menu-arrow.data-v-dd49826d {
  font-size: 22px;
  color: var(--color-text-muted, #a0aab5);
  flex-shrink: 0;
}
.menu-divider.data-v-dd49826d {
  height: 1px;
  background: var(--color-border, #e2e7ec);
  margin: 0 var(--space-md, 16px);
}

/* 退出登录 */
.logout-wrap.data-v-dd49826d {
  padding: var(--space-md, 16px);
}
.btn-logout.data-v-dd49826d {
  height: 52px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10px;
  background: #fff;
  border: 1px solid #e74c3c;
  color: #e74c3c;
  font-size: var(--font-base, 17px);
  font-weight: 600;
}

/* 底部 */
.footer.data-v-dd49826d {
  padding: 0 var(--space-md, 16px) 0;
  text-align: center;
}
.footer-text.data-v-dd49826d {
  font-size: var(--font-xs, 13px);
  color: var(--color-text-muted, #a0aab5);
}