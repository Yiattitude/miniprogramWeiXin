.page.data-v-dd49826d {
  padding: 32rpx 24rpx;
}
.profile-header.data-v-dd49826d {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.avatar-btn.data-v-dd49826d {
  background: transparent;
  padding: 0;
  margin: 0;
  border: none;
  line-height: 1;
  position: relative;
  margin-right: 32rpx;
}
.avatar-btn.data-v-dd49826d::after {
  border: none;
}
.avatar.data-v-dd49826d {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #e0e7ef;
  display: block;
}
.edit-tip.data-v-dd49826d {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 18rpx;
  color: #fff;
  background: rgba(0,0,0,0.5);
  border-radius: 0 0 60rpx 60rpx;
  padding: 6rpx 0;
}
.user-info.data-v-dd49826d {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  flex: 1;
}
.nickname-row.data-v-dd49826d {
  display: flex;
  align-items: center;
  gap: 12rpx;
  align-self: flex-start;
}
.nickname.data-v-dd49826d {
  font-size: 36rpx;
  font-weight: 600;
  color: #222;
}
.edit-icon.data-v-dd49826d {
  font-size: 22rpx;
  color: #3a7bd5;
  padding: 4rpx 12rpx;
  background: #e8f4fd;
  border-radius: 20rpx;
}
.role-badge.data-v-dd49826d {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  align-self: flex-start;
  width: fit-content;
}
.role-admin.data-v-dd49826d {
  background: #fff3e0;
  color: #e65100;
}
.role-user.data-v-dd49826d {
  background: #e8f4fd;
  color: #1565c0;
}

/* 昵称编辑弹窗样式 */
.nickname-modal.data-v-dd49826d {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-mask.data-v-dd49826d {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}
.modal-content.data-v-dd49826d {
  position: relative;
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  z-index: 1;
}
.modal-title.data-v-dd49826d {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  text-align: center;
  margin-bottom: 32rpx;
}
.modal-input.data-v-dd49826d {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  padding: 0 24rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  box-sizing: border-box;
}
.modal-btns.data-v-dd49826d {
  display: flex;
  margin-top: 32rpx;
  gap: 24rpx;
}
.modal-btn.data-v-dd49826d {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 12rpx;
}
.modal-btn.cancel.data-v-dd49826d {
  background: #f5f5f5;
  color: #666;
}
.modal-btn.confirm.data-v-dd49826d {
  background: #3a7bd5;
  color: #fff;
}

.stat-card.data-v-dd49826d {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 0;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.stat-item.data-v-dd49826d {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.stat-num.data-v-dd49826d {
  font-size: 44rpx;
  font-weight: 700;
  color: #3a7bd5;
}
.stat-label.data-v-dd49826d {
  font-size: 24rpx;
  color: #888;
}
.stat-divider.data-v-dd49826d {
  width: 1rpx;
  background: #eee;
  margin: 8rpx 0;
}
.menu-card.data-v-dd49826d {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}
.menu-item.data-v-dd49826d {
  display: flex;
  align-items: center;
  padding: 36rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.menu-item.data-v-dd49826d:last-child {
  border-bottom: none;
}
.menu-icon.data-v-dd49826d {
  font-size: 36rpx;
  margin-right: 24rpx;
}
.menu-text.data-v-dd49826d {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}
.menu-arrow.data-v-dd49826d {
  font-size: 36rpx;
  color: #ccc;
}
.logout-text.data-v-dd49826d {
  color: #e53935;
}
