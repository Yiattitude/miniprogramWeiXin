.page.data-v-2788f303 {
  min-height: 100vh;
  background: var(--color-bg-page, #f0f2f5);
  padding-bottom: 100px;
}

/* 活动标题条 */
.activity-bar.data-v-2788f303 {
  background: var(--color-primary-bg, #eef3fc);
  padding: var(--space-sm, 12px) var(--space-md, 16px);
  border-bottom: 1px solid var(--color-border, #e2e7ec);
}
.activity-name.data-v-2788f303 {
  font-size: var(--font-base, 17px);
  font-weight: 600;
  color: var(--color-primary, #3a7bd5);
}

/* 表单 */
.form-wrap.data-v-2788f303 {
  padding: var(--space-sm, 12px) var(--space-md, 16px);
  display: flex;
  flex-direction: column;
  gap: var(--space-sm, 12px);
}
.form-item.data-v-2788f303 {
  background: #fff;
  border-radius: var(--radius-md, 10px);
  padding: var(--space-md, 16px);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}
.form-label.data-v-2788f303 {
  display: block;
  font-size: var(--font-base, 17px);
  font-weight: 600;
  color: var(--color-text-main, #1e2a3a);
  margin-bottom: 10px;
}
.required.data-v-2788f303 {
  color: var(--color-danger, #e74c3c);
}
.form-hint.data-v-2788f303 {
  display: block;
  font-size: var(--font-xs, 13px);
  color: var(--color-text-muted, #a0aab5);
  margin-top: 4px;
}

/* 输入框 */
.input-wrap.data-v-2788f303 {
  display: flex;
  align-items: center;
  border: 1.5px solid var(--color-border, #e2e7ec);
  border-radius: var(--radius-sm, 6px);
  padding: 0 12px;
  height: 52px;
  gap: 8px;
}
.input-wrap.input-error.data-v-2788f303 {
  border-color: var(--color-danger, #e74c3c);
}
.form-input.data-v-2788f303 {
  flex: 1;
  font-size: var(--font-base, 17px);
  color: var(--color-text-main, #1e2a3a);
}
.input-unit.data-v-2788f303 {
  font-size: var(--font-sm, 15px);
  color: var(--color-text-sub, #6b7b8d);
  flex-shrink: 0;
}
.error-msg.data-v-2788f303 {
  display: block;
  font-size: var(--font-xs, 13px);
  color: var(--color-danger, #e74c3c);
  margin-top: 4px;
}
.placeholder.data-v-2788f303 {
  color: var(--color-text-muted, #a0aab5);
}

/* 文本域 */
.textarea-wrap.data-v-2788f303 {
  border: 1.5px solid var(--color-border, #e2e7ec);
  border-radius: var(--radius-sm, 6px);
  padding: 12px;
}
.form-textarea.data-v-2788f303 {
  width: 100%;
  min-height: 100px;
  font-size: var(--font-base, 17px);
  color: var(--color-text-main, #1e2a3a);
  line-height: 1.6;
}
.char-count.data-v-2788f303 {
  display: block;
  text-align: right;
  font-size: var(--font-xs, 13px);
  color: var(--color-text-muted, #a0aab5);
  margin-top: 4px;
}

/* 底部按钮 */
.bottom-bar.data-v-2788f303 {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: var(--space-sm, 12px) var(--space-md, 16px);
  padding-bottom: calc(var(--space-sm, 12px) + env(safe-area-inset-bottom));
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.06);
}
.btn-submit.data-v-2788f303 {
  width: 100%;
  height: 52px;
  line-height: 52px;
  text-align: center;
  background: var(--color-primary, #3a7bd5);
  color: #fff;
  font-size: var(--font-lg, 19px);
  font-weight: 600;
  border-radius: var(--radius-md, 10px);
}
.btn-submit.btn-loading.data-v-2788f303 {
  opacity: 0.7;
}