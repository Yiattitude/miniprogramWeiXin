.page.data-v-9c01f5c3 {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7f9fc 0%, #eef2f7 48%, #e9eef5 100%);
  padding-bottom: 44px;
  font-family: "HarmonyOS Sans", "PingFang SC", "Microsoft YaHei", sans-serif;
}

/* 顶部标题栏 */
.header.data-v-9c01f5c3 {
  position: relative;
  background: linear-gradient(135deg, #2f62c6 0%, #3e7ae4 100%);
  padding: 36px 16px 32px;
  box-shadow: 0 8px 24px rgba(25, 52, 110, 0.18);
  overflow: hidden;
}
.header.data-v-9c01f5c3::after {
  content: "";
  position: absolute;
  right: -30px;
  top: -30px;
  width: 120px;
  height: 120px;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.2) 0%, rgba(255, 255, 255, 0) 70%);
}
.header-title.data-v-9c01f5c3 {
  position: relative;
  z-index: 1;
  display: block;
  font-size: 22px;
  font-weight: 700;
  color: #fff;
  margin-bottom: 4px;
  letter-spacing: 0.5px;
}
.header-sub.data-v-9c01f5c3 {
  position: relative;
  z-index: 1;
  font-size: 15px;
  color: rgba(255, 255, 255, 0.88);
}

/* 功能卡片网格 */
.grid.data-v-9c01f5c3 {
  display: flex;
  flex-direction: column;
  padding: 16px;
  gap: 14px;
  margin-top: -20px;
}
.grid-item.data-v-9c01f5c3 {
  width: 100%;
  background: #fff;
  border-radius: 18px;
  padding: 18px 16px;
  box-shadow: 0 10px 20px rgba(20, 28, 46, 0.08);
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16px;
  animation: riseIn-9c01f5c3 0.5s ease-out both;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.grid-item.data-v-9c01f5c3:nth-child(1) {
  animation-delay: 0.05s;
}
.grid-item.data-v-9c01f5c3:nth-child(2) {
  animation-delay: 0.1s;
}
.grid-item.data-v-9c01f5c3:nth-child(3) {
  animation-delay: 0.15s;
}
.grid-item.data-v-9c01f5c3:nth-child(4) {
  animation-delay: 0.2s;
}
.grid-item.data-v-9c01f5c3:nth-child(5) {
  animation-delay: 0.25s;
}
.grid-item.data-v-9c01f5c3:active {
  transform: scale(0.98);
}
.grid-icon-wrap.data-v-9c01f5c3 {
  width: 52px;
  height: 52px;
  flex-shrink: 0;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.6);
}
.grid-icon.data-v-9c01f5c3 {
  font-size: 26px;
}
.grid-label.data-v-9c01f5c3 {
  font-size: 16px;
  font-weight: 600;
  color: #1c2431;
  line-height: 1.3;
}
.grid-desc.data-v-9c01f5c3 {
  font-size: 13px;
  color: #7a8797;
  margin-top: 4px;
  line-height: 1.4;
}
.grid-text.data-v-9c01f5c3 {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

/* 个人统计卡片 */
.summary-card.data-v-9c01f5c3 {
  background: #fff;
  margin: 0 16px;
  border-radius: 18px;
  padding: 16px 12px;
