.page.data-v-9a77e90c {
  min-height: 100vh;
  background: var(--color-bg-page, #f0f2f5);
}
.scroll-wrap.data-v-9a77e90c {
  height: 100vh;
  padding-bottom: 60px;
}

/* 管理员标识条 */
.admin-bar.data-v-9a77e90c {
  display: flex;
  align-items: center;
  gap: 8px;
  background: #fff3cd;
  padding: var(--space-sm, 12px) var(--space-md, 16px);
  border-bottom: 1px solid #ffc107;
}
.admin-icon.data-v-9a77e90c {
  font-size: 18px;
}
.admin-text.data-v-9a77e90c {
  font-size: var(--font-sm, 15px);
  color: #856404;
  font-weight: 600;
}

/* 表单卡片 */
.form-card.data-v-9a77e90c {
  background: #fff;
  margin: var(--space-md, 16px);
  border-radius: var(--radius-md, 10px);
  padding: var(--space-md, 16px);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}
.form-item.data-v-9a77e90c {
  margin-bottom: var(--space-md, 16px);
}
.form-item.data-v-9a77e90c:last-child {
  margin-bottom: 0;
}
.form-label.data-v-9a77e90c {
  display: block;
  font-size: var(--font-base, 17px);
  font-weight: 600;
  color: var(--color-text-main, #1e2a3a);
  margin-bottom: 8px;
}
.form-label.required.data-v-9a77e90c::before {
  content: "* ";
  color: #e74c3c;
}
.form-input.data-v-9a77e90c {
  width: 100%;
  height: 48px;
  border: 1px solid var(--color-border, #e2e7ec);
  border-radius: 8px;
  padding: 0 12px;
  font-size: var(--font-base, 17px);
  color: var(--color-text-main, #1e2a3a);
  background: #fafbfc;
  box-sizing: border-box;
}
.form-textarea.data-v-9a77e90c {
  width: 100%;
  min-height: 100px;
  border: 1px solid var(--color-border, #e2e7ec);
  border-radius: 8px;
  padding: 12px;
  font-size: var(--font-base, 17px);
  color: var(--color-text-main, #1e2a3a);
  background: #fafbfc;
  box-sizing: border-box;
  line-height: 1.6;
}
.placeholder.data-v-9a77e90c {
  color: var(--color-text-muted, #a0aab5);
}
.char-count.data-v-9a77e90c {
  display: block;
  text-align: right;
  font-size: var(--font-xs, 13px);
  color: var(--color-text-muted, #a0aab5);
  margin-top: 4px;
}
.form-hint.data-v-9a77e90c {
  font-size: var(--font-xs, 13px);
  color: var(--color-text-muted, #a0aab5);
  margin-top: 4px;
}

/* 时间选择器行 */
.form-picker-row.data-v-9a77e90c {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 48px;
  border: 1px solid var(--color-border, #e2e7ec);
  border-radius: 8px;
  padding: 0 12px;
  background: #fafbfc;
}
.picker-text.data-v-9a77e90c {
  font-size: var(--font-base, 17px);
}
.picker-text.has-val.data-v-9a77e90c {
  color: var(--color-text-main, #1e2a3a);
}
.picker-text.no-val.data-v-9a77e90c {
  color: var(--color-text-muted, #a0aab5);
}
.picker-arrow.data-v-9a77e90c {
  font-size: 22px;
  color: var(--color-text-muted, #a0aab5);
}

/* 计数器 */
.counter-row.data-v-9a77e90c {
  display: flex;
  align-items: center;
  gap: 0;
  border: 1px solid var(--color-border, #e2e7ec);
  border-radius: 8px;
  overflow: hidden;
  width: -moz-fit-content;
  width: fit-content;
}
.counter-btn.data-v-9a77e90c {
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  color: var(--color-primary, #3a7bd5);
  background: var(--color-primary-bg, #eef3fc);
  font-weight: 600;
}
.counter-input.data-v-9a77e90c {
  width: 72px;
  height: 48px;
  text-align: center;
  font-size: var(--font-lg, 19px);
  font-weight: 700;
  color: var(--color-text-main, #1e2a3a);
  border: none;
  border-left: 1px solid var(--color-border, #e2e7ec);
  border-right: 1px solid var(--color-border, #e2e7ec);
}

/* 按钮组 */
.btn-group.data-v-9a77e90c {
  display: flex;
  gap: var(--space-sm, 12px);
  padding: 0 var(--space-md, 16px) var(--space-lg, 24px);
}
.btn.data-v-9a77e90c {
  flex: 1;
  height: 52px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10px;
  font-size: var(--font-base, 17px);
  font-weight: 600;
}
.btn-primary.data-v-9a77e90c {
  background: var(--color-primary, #3a7bd5);
  color: #fff;
}
.btn-outline.data-v-9a77e90c {
  background: #fff;
  color: var(--color-primary, #3a7bd5);
  border: 1px solid var(--color-primary, #3a7bd5);
}
.btn-disabled.data-v-9a77e90c {
  background: var(--color-text-muted, #a0aab5);
  color: #fff;
  pointer-events: none;
}