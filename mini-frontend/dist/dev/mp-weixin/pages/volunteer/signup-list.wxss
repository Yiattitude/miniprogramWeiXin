.page.data-v-85a239f0 {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7f9fc 0%, #eef2f7 48%, #e9eef5 100%);
  padding-bottom: 44px;
  font-family: "HarmonyOS Sans", "PingFang SC", "Microsoft YaHei", sans-serif;
}

/* 搜索栏 */
.search-bar.data-v-85a239f0 {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
}
.search-input-wrap.data-v-85a239f0 {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f7f9fc;
  border-radius: 22px;
  padding: 0 16px;
  height: 44px;
  gap: 8px;
  transition: background 0.2s ease;
}
.search-icon.data-v-85a239f0 {
  font-size: 16px;
  flex-shrink: 0;
  color: #7a8797;
}
.search-input.data-v-85a239f0 {
  flex: 1;
  font-size: 15px;
  color: #1c2431;
  background: transparent;
}
.placeholder.data-v-85a239f0 {
  color: #a0aab5;
}
.filter-btn.data-v-85a239f0 {
  display: flex;
  align-items: center;
  gap: 4px;
  min-width: 60px;
  padding: 6px 12px;
  border-radius: 20px;
  background: #eef3fc;
  transition: all 0.2s ease;
}
.filter-text.data-v-85a239f0 {
  font-size: 14px;
  color: #2f62c6;
  font-weight: 500;
}
.filter-arrow.data-v-85a239f0 {
  font-size: 11px;
  color: #2f62c6;
}

/* 筛选面板 */
.filter-panel.data-v-85a239f0 {
  background: #fff;
  padding: 16px;
  border-bottom: 1px solid #e6ebf2;
  animation: slideDown-85a239f0 0.3s ease-out both;
}
.filter-label.data-v-85a239f0 {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #1c2431;
  margin-bottom: 10px;
}
.filter-chips.data-v-85a239f0 {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.chip.data-v-85a239f0 {
  padding: 6px 16px;
  border-radius: 20px;
  font-size: 14px;
  color: #7a8797;
  background: #f7f9fc;
  transition: all 0.2s ease;
}
.chip-active.data-v-85a239f0 {
  background: linear-gradient(135deg, #d4e9fc 0%, #c0dffe 100%);
  color: #2f62c6;
  font-weight: 600;
  box-shadow: 0 2px 8px rgba(47, 98, 198, 0.15);
}

/* 统计 */
.list-meta.data-v-85a239f0 {
  padding: 16px 16px 8px;
}
.meta-text.data-v-85a239f0 {
  font-size: 14px;
  color: #7a8797;
  font-weight: 500;
}

/* 列表 */
.list-wrap.data-v-85a239f0 {
  padding: 0 16px;
}
.loading-wrap.data-v-85a239f0 {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
  gap: 12px;
}
.loading-text.data-v-85a239f0 {
  font-size: 14px;
  color: #7a8797;
}
.empty.data-v-85a239f0 {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80px 0;
  gap: 14px;
}
.empty-icon.data-v-85a239f0 {
  font-size: 64px;
  opacity: 0.5;
}
.empty-text.data-v-85a239f0 {
  font-size: 16px;
  color: #7a8797;
  font-weight: 500;
}
@keyframes slideDown-85a239f0 {
from {
    opacity: 0;
    transform: translateY(-10px);
}
to {
    opacity: 1;
    transform: translateY(0);
}
}