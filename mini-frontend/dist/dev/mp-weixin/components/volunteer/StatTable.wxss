.stat-table.data-v-2df3b14a {
  background: #fff;
  border-radius: var(--radius-md, 10px);
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}
.table-row.data-v-2df3b14a {
  display: flex;
  border-bottom: 1px solid var(--color-border, #e2e7ec);
}
.table-row.data-v-2df3b14a:last-child {
  border-bottom: none;
}
.table-row.row-odd.data-v-2df3b14a {
  background: #f8fafc;
}
.table-cell.data-v-2df3b14a {
  flex: 1;
  padding: 12px var(--space-sm, 12px);
  font-size: var(--font-sm, 15px);
  line-height: 1.5;
  word-break: break-all;
}

/* 表头 */
.table-head.data-v-2df3b14a {
  background: var(--color-primary-bg, #eef3fc);
}
.head-cell.data-v-2df3b14a {
  font-size: var(--font-sm, 15px);
  font-weight: 600;
  color: var(--color-primary, #3a7bd5);
}

/* 数据行 */
.body-cell.data-v-2df3b14a {
  color: var(--color-text-main, #1e2a3a);
}

/* 合计行 */
.total-row.data-v-2df3b14a {
  background: var(--color-primary, #3a7bd5);
  border-bottom: none;
}
.total-cell.data-v-2df3b14a {
  font-size: var(--font-sm, 15px);
  font-weight: 600;
  color: #fff;
}

/* 空状态 */
.table-empty.data-v-2df3b14a {
  padding: var(--space-lg, 24px);
  text-align: center;
}
.empty-text.data-v-2df3b14a {
  font-size: var(--font-sm, 15px);
  color: var(--color-text-muted, #a0aab5);
}