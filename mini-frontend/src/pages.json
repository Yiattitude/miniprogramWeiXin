{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uv-loading-icon$": "@/components/stub/uv-loading-icon.vue",
      "^uv-load-more$": "@/components/stub/uv-load-more.vue",
      "^uv-upload$": "@/components/stub/uv-upload.vue",
      "^uv-(.*)": "@/components/stub/uv-fallback.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "银才荟-志愿服务平台"
      }
    },
    {
      "path": "pages/auth/login",
      "style": {
        "navigationBarTitleText": "登录"
      }
    },
    {
      "path": "pages/auth/admin-login",
      "style": {
        "navigationBarTitleText": "管理员登录"
      }
    },
    {
      "path": "pages/auth/bind",
      "style": {
        "navigationBarTitleText": "完善信息"
      }
    },
    {
      "path": "pages/volunteer/index",
      "style": {
        "navigationBarTitleText": "志愿活动"
      }
    },
    {
      "path": "pages/volunteer/profile",
      "style": {
        "navigationBarTitleText": "个人中心"
      }
    },
    {
      "path": "pages/volunteer/publish",
      "style": {
        "navigationBarTitleText": "发布活动"
      }
    },
    {
      "path": "pages/volunteer/checkin-list",
      "style": {
        "navigationBarTitleText": "志愿打卡",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/volunteer/checkin-form",
      "style": {
        "navigationBarTitleText": "打卡填报"
      }
    },
    {
      "path": "pages/volunteer/record",
      "style": {
        "navigationBarTitleText": "打卡记录",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/volunteer/statistics",
      "style": {
        "navigationBarTitleText": "统计报表"
      }
    },
    {
      "path": "pages/volunteer/honor-submit",
      "style": {
        "navigationBarTitleText": "荣誉上传"
      }
    },
    {
      "path": "pages/admin/checkin-audit",
      "style": {
        "navigationBarTitleText": "打卡审核",
        "backgroundColor": "#f0f2f5"
      }
    },
    {
      "path": "pages/admin/honor-audit",
      "style": {
        "navigationBarTitleText": "荣誉审核",
        "backgroundColor": "#f0f2f5"
      }
    },
    {
      "path": "pages/admin/user-manage",
      "style": {
        "navigationBarTitleText": "积分与用户管理",
        "backgroundColor": "#f0f2f5"
      }
    },
    {
      "path": "pages/admin/user-detail",
      "style": {
        "navigationBarTitleText": "用户明细"
      }
    },
    {
      "path": "pages/admin/statistics",
      "style": {
        "navigationBarTitleText": "全站数据总览",
        "backgroundColor": "#f0f2f5"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "银才荟-志愿服务平台",
    "navigationBarBackgroundColor": "#ffffff",
    "backgroundColor": "#f0f2f5"
  },
  "tabBar": {
    "color": "#6b7b8d",
    "selectedColor": "#3a7bd5",
    "borderStyle": "black",
    "backgroundColor": "#ffffff",
    "fontSize": "16px",
    "iconWidth": "28px",
    "spacing": "4px",
    "height": "64px",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "static/icons/home_3_line.png",
        "selectedIconPath": "static/icons/home_3_line.png"
      },
      {
        "pagePath": "pages/volunteer/index",
        "text": "志愿",
        "iconPath": "static/icons/layout_bottom_close_line.png",
        "selectedIconPath": "static/icons/layout_bottom_close_line.png"
      },
      {
        "pagePath": "pages/volunteer/profile",
        "text": "我的",
        "iconPath": "static/icons/user_4_line.png",
        "selectedIconPath": "static/icons/user_4_line.png"
      }
    ]
  }
}
